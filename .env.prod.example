# Production Environment Variables
# Copy to .env.prod and fill with your actual values
# NEVER commit .env.prod to git!

# Django Security
# Generate SECRET_KEY with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=your-very-secret-key-generate-a-strong-one-here
DEBUG=False
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com

# Database
DATABASE_NAME=learnhub_db
DATABASE_USER=learnhub_user
# Create a STRONG password - do not use the default!
DATABASE_PASSWORD=your-super-secure-postgres-password-here

# Database Port (optional, default: 5432)
# DATABASE_PORT=5432

# Host port mapping (optional, default: 3000)
# Maps external port to internal container port 3000
# HOST_WEB_PORT_PROD=3000
