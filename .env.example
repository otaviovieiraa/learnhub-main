# Exemplo de arquivo .env para o projeto LearnHub
# Copie este arquivo para .env e ajuste os valores para seu ambiente

# Segurança
SECRET_KEY=your-super-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuração do banco de dados (usado por docker-compose e Django)
# Para produção recomendo usar: django.db.backends.postgresql
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=learnhub_db
DATABASE_USER=learnhub_user
DATABASE_PASSWORD=postgres_secure_password_here
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Mapeamento de portas (host:container)
# Porta interna do aplicativo (usada em Dockerfile e pela aplicação)
APP_PORT=3000

# Portas expostas no host para os containers
# PostgreSQL (host:container)
HOST_POSTGRES_PORT=5432

# Web - desenvolvimento (host:container)
HOST_WEB_PORT_DEV=3000

# Web - produção (host:container)
HOST_WEB_PORT_PROD=3010
